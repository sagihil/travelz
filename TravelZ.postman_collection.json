            }
          }
        },
        {
          "name": "Remove Interest From My Profile",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/interests/me/{{interestId}}", "host": ["{{baseUrl}}"], "path": ["interests","me","{{interestId}}"] }
          }
        }
      ]
    },

    {
      "name": "AI Travel Agent",
      "item": [
        {
          "name": "Ask AI - Recommend Attractions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/travel-agent", "host": ["{{baseUrl}}"], "path": ["ai","travel-agent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": {{tripId}},\n  \"message\": \"Recommend 3 top attractions for my trip and add them to Day 1\"\n}"
            },
            "description": "The AI reads the trip destination, filters matching attractions from the DB, and returns recommendations + actions (ADD/REMOVE/UPDATE). Actions are applied to the DB automatically."
          }
        },
        {
          "name": "Ask AI - Add Specific Country",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/travel-agent", "host": ["{{baseUrl}}"], "path": ["ai","travel-agent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": {{tripId}},\n  \"message\": \"Also add attractions from Jordan for Day 3\"\n}"
            }
          }
        },
        {
          "name": "Ask AI - Remove Attraction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/travel-agent", "host": ["{{baseUrl}}"], "path": ["ai","travel-agent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": {{tripId}},\n  \"message\": \"Remove all attractions from Day 2\"\n}"
            }
          }
        },
        {
          "name": "Ask AI - Advisory Question",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/ai/travel-agent", "host": ["{{baseUrl}}"], "path": ["ai","travel-agent"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tripId\": {{tripId}},\n  \"message\": \"What is the best time to visit and what should I pack?\"\n}"
            }
          }
        }
      ]
    },

    {
      "name": "Online Users (WebSocket REST)",
      "item": [
        {
          "name": "Get Online Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/online-users", "host": ["{{baseUrl}}"], "path": ["online-users"] },
            "description": "Admin only. Returns list of currently connected users tracked via Socket.IO."
          }
        }
      ]
    },

    {
      "name": "Settings",
      "item": [
        {
          "name": "Get My Settings",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/settings", "host": ["{{baseUrl}}"], "path": ["settings"] }
          }
        },
        {
          "name": "Update My Settings",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/settings", "host": ["{{baseUrl}}"], "path": ["settings"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"theme\": \"dark\"\n}"
            }
          }
        }
      ]
    }

  ]
}
