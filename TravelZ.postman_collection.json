{
  "info": {
    "name": "TravelZ API",
    "description": "Full API collection for TravelZ — Assignment 4\n\nHow to use:\n1. Run the Login request first\n2. The token is saved automatically to the {{token}} variable\n3. All protected routes use {{token}} automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api", "type": "string" },
    { "key": "token",   "value": "", "type": "string" },
    { "key": "userId",       "value": "1",  "type": "string" },
    { "key": "tripId",       "value": "1",  "type": "string" },
    { "key": "attractionId", "value": "1",  "type": "string" },
    { "key": "interestId",   "value": "1",  "type": "string" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    pm.collectionVariables.set('userId', String(res.data.user.userId));",
                  "    console.log('Token saved:', res.data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"hila.sagi@travelz.com\",\n  \"password\": \"Admin@123\"\n}"
            },
            "description": "Login and auto-save the JWT token.\n\nTest accounts:\n- admin:   hila.sagi@travelz.com / Admin@123\n- manager: noa.levi@travelz.com / Manager@1\n- user:    daniel.cohen@travelz.com / Daniel@456"
          }
        },
        {
          "name": "Login as User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    pm.collectionVariables.set('userId', String(res.data.user.userId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"daniel.cohen@travelz.com\",\n  \"password\": \"Daniel@456\"\n}"
            }
          }
        },
        {
          "name": "Login as Manager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.token) {",
                  "    pm.collectionVariables.set('token', res.data.token);",
                  "    pm.collectionVariables.set('userId', String(res.data.user.userId));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noa.levi@travelz.com\",\n  \"password\": \"Manager@1\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] }
          }
        }
      ]
    },

    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "description": "Admin only"
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users","me"] }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] }
          }
        },
        {
          "name": "Register New User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/users", "host": ["{{baseUrl}}"], "path": ["users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"email\": \"test.user@travelz.com\",\n  \"password\": \"Test@1234\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Updated\",\n  \"lastName\": \"Name\"\n}"
            }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users","{{userId}}"] },
            "description": "Admin only"
          }
        }
      ]
    },

    {
      "name": "Attractions",
      "item": [
        {
          "name": "Get All Attractions",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/attractions", "host": ["{{baseUrl}}"], "path": ["attractions"] }
          }
        },
        {
          "name": "Get All Attractions (filtered by country)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/attractions?country=Israel",
              "host": ["{{baseUrl}}"],
              "path": ["attractions"],
              "query": [{ "key": "country", "value": "Israel" }]
            }
          }
        },
        {
          "name": "Get Attraction By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/attractions/{{attractionId}}", "host": ["{{baseUrl}}"], "path": ["attractions","{{attractionId}}"] }
          }
        },
        {
          "name": "Create Attraction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/attractions", "host": ["{{baseUrl}}"], "path": ["attractions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"BGU Campus\",\n  \"city\": \"Beer Sheva\",\n  \"country\": \"Israel\",\n  \"category\": \"Landmark\",\n  \"description\": \"Ben-Gurion University of the Negev\",\n  \"rating\": 4.2\n}"
            }
          }
        },
        {
          "name": "Update Attraction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/attractions/{{attractionId}}", "host": ["{{baseUrl}}"], "path": ["attractions","{{attractionId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Eiffel Tower\",\n  \"city\": \"Paris\",\n  \"country\": \"France\",\n  \"category\": \"Landmark\",\n  \"rating\": 4.8\n}"
            },
            "description": "Manager or Admin only"
          }
        },
        {
          "name": "Delete Attraction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/attractions/{{attractionId}}", "host": ["{{baseUrl}}"], "path": ["attractions","{{attractionId}}"] },
            "description": "Admin only"
          }
        }
      ]
    },

    {
      "name": "Trips",
      "item": [
        {
          "name": "Get All Trips",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/trips", "host": ["{{baseUrl}}"], "path": ["trips"] },
            "description": "User sees only own trips. Manager/Admin see all."
          }
        },
        {
          "name": "Get Trip By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}"] }
          }
        },
        {
          "name": "Create Trip",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success && res.data && res.data.id) {",
                  "    pm.collectionVariables.set('tripId', String(res.data.id));",
                  "    console.log('Trip ID saved:', res.data.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/trips", "host": ["{{baseUrl}}"], "path": ["trips"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Israel & Jordan Adventure\",\n  \"description\": \"Exploring the Middle East\",\n  \"startDate\": \"2025-06-01\",\n  \"endDate\": \"2025-06-10\"\n}"
            }
          }
        },
        {
          "name": "Update Trip",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Trip Title\",\n  \"description\": \"Updated description\",\n  \"startDate\": \"2025-07-01\",\n  \"endDate\": \"2025-07-14\"\n}"
            }
          }
        },
        {
          "name": "Delete Trip",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}"] }
          }
        },
        {
          "name": "Get Attractions In Trip",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}/attractions", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}","attractions"] },
            "description": "Returns attractions with TripAttraction metadata (dayNumber, orderInDay, notes). Demonstrates Many-to-Many ORM relationship."
          }
        },
        {
          "name": "Add Attraction To Trip",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}/attractions", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}","attractions"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"attractionId\": {{attractionId}},\n  \"dayNumber\": 1,\n  \"orderInDay\": 1,\n  \"notes\": \"Book tickets in advance\"\n}"
            }
          }
        },
        {
          "name": "Remove Attraction From Trip",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/trips/{{tripId}}/attractions/{{attractionId}}", "host": ["{{baseUrl}}"], "path": ["trips","{{tripId}}","attractions","{{attractionId}}"] }
          }
        }
      ]
    },

    {
      "name": "Interests",
      "item": [
        {
          "name": "Get All Interests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/interests", "host": ["{{baseUrl}}"], "path": ["interests"] }
          }
        },
        {
          "name": "Get My Interests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/interests/me", "host": ["{{baseUrl}}"], "path": ["interests","me"] }
          }
        },
        {
          "name": "Add Interest to My Profile",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/interests/me", "host": ["{{baseUrl}}"], "path": ["interests","me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"interestId\": {{interestId}}\n}"
            }
          }
        },
        {
          "name": "Replace All My Interests",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{baseUrl}}/interests/me", "host": ["{{baseUrl}}"], "path": ["interests","me"] },
